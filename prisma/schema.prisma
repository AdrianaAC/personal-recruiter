generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String           @id @default(cuid())
  name         String?
  email        String           @unique
  passwordHash String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]
  contacts     Contact[]
  tasks        Task[]
  callUps      CallUp[]
}

model JobApplication {
  id             String            @id @default(cuid())
  userId         String
  companyName    String
  roleTitle      String
  location       String?
  workMode       WorkMode?
  salaryMin      Int?
  salaryMax      Int?
  currency       String?
  source         String?
  jobUrl         String?
  jobDescription String?
  status         ApplicationStatus @default(SAVED)
  priority       Priority          @default(MEDIUM)
  archivedAt     DateTime?
  appliedAt      DateTime?
  nextStep       String?
  notesSummary   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews Interview[]
  notes      Note[]
  tasks      Task[]
  contacts   ApplicationContact[]
  callUps    CallUp[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, archivedAt])
  @@index([userId, archivedAt, updatedAt])
}

model Interview {
  id              String            @id @default(cuid())
  applicationId   String
  type            InterviewType
  stageName       String?
  scheduledAt     DateTime?
  durationMinutes Int?
  interviewerName String?
  interviewerRole String?
  locationOrLink  String?
  outcome         InterviewOutcome?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Note {
  id            String   @id @default(cuid())
  applicationId String
  title         String?
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Task {
  id            String    @id @default(cuid())
  userId        String
  applicationId String?
  title         String
  description   String?
  dueDate       DateTime?
  completed     Boolean   @default(false)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([applicationId])
  @@index([userId, archivedAt, completed, updatedAt])
  @@index([userId, archivedAt, completed, dueDate])
}

model Contact {
  id          String   @id @default(cuid())
  userId      String
  fullName    String
  email       String?
  phone       String?
  linkedinUrl String?
  companyName String?
  jobTitle    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ApplicationContact[]
  callUps      CallUp[]

  @@index([userId])
  @@index([companyName])
  @@index([fullName])
}

model CallUp {
  id            String       @id @default(cuid())
  userId        String
  applicationId String?
  contactId     String?
  title         String
  description   String?
  notes         String?
  scheduledAt   DateTime?
  status        CallUpStatus @default(PLANNED)
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  contact     Contact?        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([applicationId])
  @@index([contactId])
  @@index([userId, archivedAt, updatedAt])
  @@index([userId, archivedAt, status, scheduledAt])
}

model ApplicationContact {
  id            String                 @id @default(cuid())
  applicationId String
  contactId     String
  role          ApplicationContactRole @default(OTHER)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  contact     Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([applicationId, contactId, role])
  @@index([applicationId])
  @@index([contactId])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SCREENING
  TECHNICAL_INTERVIEW
  TAKE_HOME
  FINAL_INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum InterviewType {
  RECRUITER
  TECHNICAL
  BEHAVIORAL
  MANAGER
  PANEL
  TAKE_HOME_REVIEW
  FINAL
  OTHER
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  CANCELLED
}

enum ApplicationContactRole {
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  REFERRAL
  COORDINATOR
  OTHER
}

enum CallUpStatus {
  PLANNED
  DONE
  MISSED
}
